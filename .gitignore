# ─────────────────────────────────────────────────────────────
#  BitMask — Comprehensive Git Ignore Policy
# ─────────────────────────────────────────────────────────────

# Dependency Directories
node_modules/
jspm_packages/
web_modules/
.npm/

# Environment Configurations (Strictly Kept Local for Security)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Runtime Logs & Debug Files
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Diagnostics and Process Reports
pids/
*.pid
*.seed
*.pid.lock
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# OS-Specific Cache & System Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE & Text Editor Configurations
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/
